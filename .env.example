# Copy this file to .env and fill in your values, then run: npm run deploy
# .env is gitignored — credentials never leave your machine.

# ── Site URL ─────────────────────────────────────────────────────────────────
# Your deployed domain (no trailing slash).
# Examples:
#   SITE_URL=https://cf-ai-demos.example.com
#   SITE_URL=https://my-worker.workers.dev
#
SITE_URL=https://orange-ai.serioustek.net

# ── Cloudflare Auth (local npm run deploy only) ───────────────────────────────
# Not needed if you use the "Deploy to Cloudflare" button — that flow
# authenticates via Cloudflare's web UI on their servers.
#
# Required for local deploys, especially on corporate networks where
# wrangler login's OAuth flow is blocked by SSL inspection proxies.
#
# Create a token at: https://dash.cloudflare.com/profile/api-tokens
# Use the "Edit Cloudflare Workers" template (Workers:Edit + Account:Read)
#
# CLOUDFLARE_API_TOKEN=your_api_token_here
# CLOUDFLARE_ACCOUNT_ID=your_account_id_here
